# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_DB_PASSWORD=your-supabase-db-password

# Brevo - Email delivery (get key at brevo.com)
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=your-verified-sender-email
BREVO_FROM_NAME=your-sender-display-name

# Resend - Legacy email delivery (deprecated, use Brevo instead)
RESEND_API_KEY=your-resend-api-key

# Hostinger SMTP - Legacy (not used, SMTP blocked on Supabase Edge Functions)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-email-password
SMTP_FROM="Your App <your-email@yourdomain.com>"
